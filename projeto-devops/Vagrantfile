# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|
  
  # Trigger para desabilitar DHCP do VirtualBox (CORRETO)
  config.trigger.before :"Vagrant::Action::Builtin::WaitForCommunicator", type: :action do |t|
    t.warn = "Interrompe o servidor dhcp do virtualbox"
    t.run = {inline: "vboxmanage dhcpserver stop --interface vboxnet0"}
  end

  # Definição geral das VMs
  config.vm.box = "debian/bookworm64"
  config.ssh.insert_key = false
  
  # VM Servidor de Arquivos (arq)
  config.vm.define "arq" do |arq|
    arq.vm.hostname = "arq.pedro.barbosa.devops"
    arq.vm.network "private_network", ip: "192.168.56.20"
    
    arq.vm.provider "virtualbox" do |vb|
      vb.memory = "512"
      vb.linked_clone = true
      vb.check_guest_additions = false
      
      # Criar 3 discos adicionais de 10GB cada
      for i in 1..3
        disk_path = "disks/arq_disk#{i}.vdi"
        unless File.exist?(disk_path)
          vb.customize ["createhd", "--filename", disk_path, "--size", 10240]
        end
        vb.customize ["storageattach", :id, "--storagectl", "SATA Controller", 
                     "--port", i, "--device", 0, "--type", "hdd", "--medium", disk_path]
      end
    end
    
    arq.vm.provision "shell", inline: <<-SHELL
      apt-get update
      apt-get install -y python3
    SHELL
  end

  # VM Servidor de Banco de Dados (db)
  config.vm.define "db" do |db|
    db.vm.hostname = "db.pedro.barbosa.devops"
    db.vm.network "private_network", type: "dhcp", 
                  mac: "080027AABB01",
                  auto_config: true
    
    db.vm.provider "virtualbox" do |vb|
      vb.memory = "512"
      vb.linked_clone = true
      vb.check_guest_additions = false
    end
    
    db.vm.provision "shell", inline: <<-SHELL
      apt-get update
      apt-get install -y python3
    SHELL
  end

  # VM Servidor de Aplicação (app)
  config.vm.define "app" do |app|
    app.vm.hostname = "app.pedro.barbosa.devops"
    app.vm.network "private_network", type: "dhcp",
                  mac: "080027AABB02",
                  auto_config: true
    
    app.vm.provider "virtualbox" do |vb|
      vb.memory = "512"
      vb.linked_clone = true
      vb.check_guest_additions = false
    end
    
    app.vm.provision "shell", inline: <<-SHELL
      apt-get update
      apt-get install -y python3
    SHELL
  end

  # VM Cliente (cli)
  config.vm.define "cli" do |cli|
    cli.vm.hostname = "cli.pedro.barbosa.devops"
    cli.vm.network "private_network", type: "dhcp"
    
    cli.vm.provider "virtualbox" do |vb|
      vb.memory = "1024"
      vb.linked_clone = true
      vb.check_guest_additions = false
    end
    
    cli.vm.provision "shell", inline: <<-SHELL
      apt-get update
      apt-get install -y python3
    SHELL
  end

end
